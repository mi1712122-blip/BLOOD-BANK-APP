rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    match /donors/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(orgId);
      allow update: if isSignedIn() && isOwner(orgId);
      allow delete: if isSignedIn() && isOwner(orgId);
    }

    match /hospitals/{hospitalId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(hospitalId);
      allow update: if isSignedIn() && isOwner(hospitalId);
      allow delete: if isSignedIn() && isOwner(hospitalId);
    }

    match /bloodRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /bloodInventory/{inventoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
